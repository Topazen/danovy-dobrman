<section id="order" class="order" aria-labelledby="order-title">
    <h2 id="order-title">@Model.Texts["OrderTitle"]</h2>

    <form method="post" enctype="multipart/form-data" novalidate>
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>
                <span>@Model.Texts["FieldName"]</span>
                <input asp-for="Name" required />
            </label>
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>
                <span>@Model.Texts["FieldEmail"]</span>
                <input asp-for="Email" type="email" required />
            </label>
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>
                <span>@Model.Texts["FieldPhone"]</span>
                <input asp-for="Phone" />
            </label>
            <span asp-validation-for="Phone" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>
                <span>@Model.Texts["FieldMessage"]</span>
                <textarea asp-for="Message" rows="4"></textarea>
            </label>
            <span asp-validation-for="Message" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>
                <span>📎 Přílohy (volitelné)</span>
                <input type="file" asp-for="Attachments" multiple accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png" />
                <small class="file-upload-hint">Maximálně 5 souborů, každý do 10 MB. Povolené typy: PDF, Word, Excel, obrázky.</small>
            </label>
        </div>

        <div class="form-group captcha-group">
            <div class="g-recaptcha" data-sitekey="@Model.RecaptchaSiteKey"></div>
            <input type="hidden" asp-for="RecaptchaResponse" id="recaptchaResponse" />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn primary">@Model.Texts["SendButton"]</button>
            <a class="btn outline" href="tel:+420721759410">@Model.Texts["CallButton"]</a>
        </div>

        @if (!string.IsNullOrEmpty(Model.Alert))
        {
            @if (Model.Alert.Contains("úspěšně") || Model.Alert.Contains("successfully") || Model.Alert.Contains("успішно"))
            {
                <div class="alert alert-success">
                    <span class="alert-icon">✓</span>
                    <span class="alert-text">@Model.Alert</span>
                </div>
            }
            else
            {
                <div class="alert alert-error">
                    <span class="alert-icon">✕</span>
                    <span class="alert-text">@Model.Alert</span>
                </div>
            }
        }
    </form>
</section>

