@page
@using UcetnictviSite.Pages
@model IndexModel
@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.Texts["Title"];
    ViewData["Description"] = Model.Texts["Description"];
    ViewData["Lang"] = Model.Lang;
}

<section id="hero" class="hero" aria-labelledby="hero-title">
    <div class="hero-logo" aria-hidden="true"></div>
    <div class="business-name">
        <span class="business-name-main">Bc. Šárka Cimburková</span>
        <span class="business-name-tagline">Daňový Dobrman</span>
    </div>
    <h1 id="hero-title">@Model.Texts["HeroTitle"]</h1>
    <p class="lead">@Model.Texts["HeroSubtitle"]</p>
    <div class="hero-ctas">
        <a class="btn primary" href="#order">@Model.Texts["OrderNow"]</a>
        <a class="btn outline" href="#services">@Model.Texts["OurServices"]</a>
    </div>
</section>

<!-- Mobile Quick Access Menu (placed under hero for mobile) -->
<div class="mobile-quick-access">
    <a href="#services" class="quick-access-card quick-access-services">
        <div class="quick-access-icon">📊</div>
        <div class="quick-access-label">Služby</div>
    </a>
    <a href="#pricing" class="quick-access-card quick-access-pricing">
        <div class="quick-access-icon">💰</div>
        <div class="quick-access-label">Ceník</div>
    </a>
    <a href="#order" class="quick-access-card quick-access-contact">
        <div class="quick-access-icon">📬</div>
        <div class="quick-access-label">Kontakt</div>
    </a>
    <a href="tel:+420721759410" class="quick-access-card quick-access-call">
        <div class="quick-access-icon">📞</div>
        <div class="quick-access-label">Zavolat</div>
    </a>
</div>

<!-- Brand Story Section -->
<section id="brand-story" class="brand-story" aria-labelledby="brand-story-title">
    <div class="brand-story-wrapper">
        <div class="brand-story-content-side">
            <h2 id="brand-story-title">Proč právě Daňový dobrman</h2>
            
            <div class="brand-story-text">
                <p class="brand-story-intro">
                    Název <strong>Daňový dobrman</strong> odkazuje na příběh Karla Dobermanna - výběrčího daní, 
                    který vyšlechtil svého věrného společníka, aby ho chránil při práci.
                </p>
                
                <div class="brand-story-details">
                    <p>
                        Dobrman byl vyšlechtěn v 19. století v Německu mužem jménem <strong>Karl Friedrich Louis Dobermann</strong> - 
                        výběrčím daní, strážníkem a správcem psince.
                    </p>
                    <p>
                        Při své práci potřeboval psa, který by ho chránil při obchůzkách a výběru peněz. 
                        Hledal společníka, který bude <strong>odvážný, spolehlivý, chytrý a vždy připravený jednat</strong>.
                    </p>
                    <p>
                        Z několika pracovních a hlídacích plemen nakonec vznikl pes, který tyto vlastnosti dokonale spojil - dobrman. 
                        Silný, rychlý, oddaný a s neobyčejnou inteligencí se brzy stal <strong>symbolem věrnosti, disciplíny a preciznosti</strong>.
                    </p>
                </div>
                
                <div class="brand-story-highlight">
                    <p>
                        Stejně jako tehdy dobrman hlídal výběrčího daní, dnes <strong>Daňový dobrman hlídá vaše účetnictví, 
                        daně a finanční jistotu</strong>.
                    </p>
                    <p>
                        Zajišťuji, aby vše bylo v pořádku, přesné a odevzdané včas. Hlídám zákonné termíny, 
                        sleduji změny v předpisech a pečuji o vaše podnikání s dobrmaní pozorností a loajalitou.
                    </p>
                </div>
                
                <p class="brand-story-tagline">
                    <strong>Daňový dobrman</strong> - spolehlivý partner, který hlídá vaše daně s přesností a oddaností pravého hlídacího psa.
                </p>
            </div>
        </div>
        
        <div class="brand-story-slideshow">
            <div class="dog-slideshow-container">
                <div class="dog-slide active">
                    <img src="~/images/dog-vernost.jpg" alt="Věrný dobrman - vedení účetnictví Plzeň" class="dog-image" />
                </div>
                <div class="dog-slide">
                    <img src="~/images/dog-rychlost.jpg" alt="Rychlý dobrman - daňové poradenství" class="dog-image" />
                </div>
                <div class="dog-slide">
                    <img src="~/images/dog-presnost.jpg" alt="Přesný dobrman - účetní služby" class="dog-image" />
                </div>
                <div class="dog-slide">
                    <img src="~/images/dog-inteligence.jpg" alt="Inteligentní dobrman - mzdová agenda" class="dog-image" />
                </div>
            </div>
            <div class="slideshow-content-bottom">
                <div class="slideshow-container">
                    <div class="slide active">
                        <div class="slide-content">
                            <div class="slide-icon">🛡️</div>
                            <h3>Věrnost</h3>
                            <p>Stejně jako dobrman je věrný svému pánovi, jsem věrná vašemu podnikání</p>
                        </div>
                    </div>
                    <div class="slide">
                        <div class="slide-content">
                            <div class="slide-icon">⚡</div>
                            <h3>Rychlost</h3>
                            <p>Rychlá reakce na změny a včasné plnění termínů</p>
                        </div>
                    </div>
                    <div class="slide">
                        <div class="slide-content">
                            <div class="slide-icon">🎯</div>
                            <h3>Přesnost</h3>
                            <p>Precizní vedení účetnictví bez chyb a nesrovnalostí</p>
                        </div>
                    </div>
                    <div class="slide">
                        <div class="slide-content">
                            <div class="slide-icon">🧠</div>
                            <h3>Inteligence</h3>
                            <p>Chytré řešení daňových situací a optimalizace nákladů</p>
                        </div>
                    </div>
                </div>
                <div class="slideshow-dots">
                    <span class="dot active" data-slide="0"></span>
                    <span class="dot" data-slide="1"></span>
                    <span class="dot" data-slide="2"></span>
                    <span class="dot" data-slide="3"></span>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="approach" class="our-approach" aria-labelledby="approach-title">
    <h2 id="approach-title">@Model.Texts["ApproachTitle"]</h2>
    <div class="approach-grid">
        <div class="approach-item">
            <div class="approach-icon">📊</div>
            <h3>@Model.Texts["Approach1_Title"]</h3>
            <p>@Model.Texts["Approach1_Text"]</p>
        </div>
        <div class="approach-item">
            <div class="approach-icon">🔒</div>
            <h3>@Model.Texts["Approach2_Title"]</h3>
            <p>@Model.Texts["Approach2_Text"]</p>
        </div>
        <div class="approach-item">
            <div class="approach-icon">💡</div>
            <h3>@Model.Texts["Approach3_Title"]</h3>
            <p>@Model.Texts["Approach3_Text"]</p>
        </div>
    </div>
</section>

<section class="team-image" aria-label="@Model.Texts["TeamImageAlt"]">
    <div class="team-image-container">
        <img src="~/images/dog-standing.jpg"
             alt="@Model.Texts["TeamImageAlt"]"
             loading="lazy"
             class="team-photo" />
        <div class="team-image-overlay">
            <p class="team-image-text">@Model.Texts["TeamImageText"]</p>
        </div>
    </div>
</section>

<!-- Pricing Section -->
<section id="pricing" class="pricing" aria-labelledby="pricing-title">
    <h2 id="pricing-title">Ceník účetních služeb 2026</h2>
    
    <div class="pricing-container">
        <!-- Service Category Buttons on the Left -->
        <div class="pricing-period-selector">
            <button class="period-btn active" data-service="osvc">
                <span class="period-text">Daňová evidence (OSVČ)</span>
            </button>
            <button class="period-btn" data-service="podvojne">
                <span class="period-text">Podvojné účetnictví (malé s.r.o.)</span>
            </button>
            <button class="period-btn" data-service="mzdy">
                <span class="period-text">Mzdová agenda</span>
            </button>
            <button class="period-btn" data-service="danovepriznani">
                <span class="period-text">Daňová přiznání</span>
            </button>
            <button class="period-btn" data-service="poradenstvi">
                <span class="period-text">Poradenství a ostatní služby</span>
            </button>
        </div>
        
        <!-- Pricing Cards Grid -->
        <div class="pricing-grid">
            <!-- Plan 1: Start -->
            <div class="price-plan-1" id="plan-1">
                <div class="plan-top">
                    <h3>Start</h3>
                </div>
                <div class="plan-cost" data-price-display>od 1 500 Kč</div>
                <div class="plan-info-1">
                    <a href="#order" class="btn primary">Objednat službu</a>
                </div>
            </div>
            <!-- Plan 2: Business -->
            <div class="price-plan-2 featured" id="plan-2">
                <div class="plan-badge">Nejoblíbenější</div>
                <div class="plan-top">
                    <h3>Business</h3>
                </div>
                <div class="plan-cost" data-price-display>od 2 200 Kč</div>
                <div class="plan-info-2">
                    <a href="#order" class="btn primary">Objednat službu</a>
                </div>
            </div>
        </div>
    </div>
</section>

